{
  "name": "trade-royal-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend for the Trade Royal 1-hour AI-agent trading competition on the Unlink privacy protocol",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "docker:start": "docker compose -f docker-compose/compose.yml up --build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "@hono/node-server": "1.19.14",
    "@hono/node-ws": "1.3.1",
    "@hono/zod-validator": "0.4.3",
    "@privy-io/node": "0.21.0",
    "@unlink-xyz/sdk": "canary",
    "bignumber.js": "11.1.3",
    "hono": "4.7.7",
    "ioredis": "5.6.1",
    "pino": "9.6.0",
    "viem": "2.47.6",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.25.1",
    "@types/node": "24.0.1",
    "eslint": "9.25.1",
    "pino-pretty": "13.0.0",
    "tsx": "4.19.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0",
    "vitest": "3.1.2"
  }
}
