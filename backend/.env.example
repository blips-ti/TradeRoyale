# HTTP port the server listens on.
PORT=3000

# Upstash Redis connection string. Use rediss:// (TLS) for hosted Upstash.
REDIS_URL=rediss://default:PASSWORD@your-instance.upstash.io:6379

# Unlink admin API key from dashboard.unlink.xyz (server-only, privileged).
UNLINK_API_KEY=REPLACE_ME_FROM_dashboard.unlink.xyz

# Named hosted Unlink environment. Unlink's published list only names TESTNETs so far
# (base-sepolia, ethereum-sepolia, arc-testnet, ...). The rest of the defaults are Base
# MAINNET — before a real mainnet game, set this to Unlink's Base-mainnet environment name.
UNLINK_ENVIRONMENT=base-sepolia

# ERC-20 entry token. Default is Base MAINNET USDC (matches CHAIN_ID 8453 / mainnet RPC).
# Base Sepolia testnet USDC is 0x036CbD53842c5426634e7929541eC2318f3dCF7e.
ENTRY_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# 32-byte hex key for AES-256-GCM mnemonic encryption. Generate with: openssl rand -hex 32
MNEMONIC_ENCRYPTION_KEY=REPLACE_ME_WITH_openssl_rand_hex_32

# Deposit poll cadence in milliseconds.
DEPOSIT_POLL_INTERVAL_MS=5000

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Anthropic API key for the per-player trading agents. Required only once a game starts
# (the client is lazy-built); boot does not crash without it.
ANTHROPIC_API_KEY=REPLACE_ME

# Claude model the trading agents run on.
AGENT_MODEL=claude-opus-4-8

# Continuous per-player loop pacing (the agent sets its own pace via the `wait` tool):
#  - MIN_LOOP_INTERVAL_MS: hard floor between an agent's turns (cost backstop), default 10s.
#  - DEFAULT_WAIT_SECONDS: wait applied after a turn when the agent didn't call `wait`.
#  - AGENT_MAX_TURNS_PER_GAME: hard turn cap per player per game (0 = unlimited).
MIN_LOOP_INTERVAL_MS=10000
DEFAULT_WAIT_SECONDS=30
AGENT_MAX_TURNS_PER_GAME=0

# Optional LI.FI API key. Used both as the REST x-lifi-api-key header and as the LI.FI MCP
# Authorization Bearer token. Without it: 200 req / 2h; with it: 200 req / min.
# LIFI_API_KEY=

# Link the agent to LI.FI's hosted MCP server via the Anthropic MCP connector (default true).
# When false, the agent falls back to the REST-wrapped get_market / get_swap_quote tools.
AGENT_USE_LIFI_MCP=true

# LI.FI hosted MCP endpoint (Streamable HTTP).
LIFI_MCP_URL=https://mcp.li.quest/mcp

# Privy server-wallet credentials (dashboard.privy.io). Each player gets a TEE-backed Privy
# wallet that trades publicly on Base with app-sponsored gas. Required once a game starts;
# the client is lazy-built so boot never crashes without them.
PRIVY_APP_ID=REPLACE_ME_FROM_dashboard.privy.io
PRIVY_APP_SECRET=REPLACE_ME_FROM_dashboard.privy.io

# Public Base RPC for erc20 reads (allowance/balance/multicall) and confirming Privy sends.
BASE_RPC_URL=https://mainnet.base.org

# The only chain trades run on (8453 = Base mainnet). Cross-chain/bridging is rejected.
CHAIN_ID=8453

# Display / portfolio-seed set of well-known Base tokens (entry USDC first) — NOT a trade
# whitelist. The agent may trade any token LI.FI can quote on Base. Defaults to Base USDC + WETH.
TRADEABLE_TOKENS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913,0x4200000000000000000000000000000000000006

# Slippage policy for EVERY LI.FI quote (in-game swaps AND settlement liquidation).
#  - 'auto' (default): defer to LI.FI's liquidity-adaptive slippage — liquid tokens stay tight,
#    illiquid/long-tail tokens get a wider buffer so they can be sold back to USDC. We send a
#    generous slippage buffer and bound risk with MAX_PRICE_IMPACT + the quote's toAmountMin
#    (no fixed-bps hard reject).
#  - a positive integer (<= 10000): pins a fixed bps cap and hard-rejects quotes that exceed it
#    (e.g. 100 = 1%). Use only if you need a strict, predictable ceiling.
MAX_SLIPPAGE_BPS=auto

# Auto-mode guard only: LI.FI maxPriceImpact as a decimal fraction (0.5 = 50%). Routes with more
# price impact than this are hidden. Generous by default so settlement can sell long-tail tokens;
# toAmountMin remains the real on-chain protection. Ignored when MAX_SLIPPAGE_BPS is a number.
MAX_PRICE_IMPACT=0.5

# Octav public NAV API (Phase-3 independent cross-check). Key carried as Authorization: Bearer.
# Lazy client — only hit at settlement; boot does not crash without it.
OCTAV_API_KEY=REPLACE_ME_FROM_data.octav.fi
OCTAV_API_URL=https://api.octav.fi/v1

# Liquidation dust floor: at settlement, positions worth less than this base-unit USDC value
# are skipped (not liquidated). Default 1000000 = 1 USDC.
LIQUIDATION_MIN_USDC=1000000
