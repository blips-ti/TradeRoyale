# Copy to .env.local and fill in.
# Get a Privy app id at https://dashboard.privy.io  (App settings → Clients)
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: where the browser should reach the Socket.IO server.
# Leave empty to use same-origin (the custom server.mjs serves both Next + sockets).
NEXT_PUBLIC_SOCKET_URL=
